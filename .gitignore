# Exact reviewed bundled assets. Add future exceptions one file at a time only
# after recording provenance, license, byte size, SHA-256, and integrity tests.
!/src/workbench/resources/model_bundles/deepinv-mri-modl/weights.npz
!/src/workbench/resources/model_bundles/deepinv-mri-modl/golden.npz
!/src/workbench/resources/model_bundles/dival-lodopab-fbpunet/weights.npz
!/src/workbench/resources/model_bundles/dival-lodopab-fbpunet/golden.npz
!/src/workbench/resources/model_bundles/monai-brats-segmentation/model.ts
!/src/workbench/resources/model_bundles/monai-brats-segmentation/golden.npz
!/src/workbench/resources/teaching_cases/lodopab-ct/sample.npz

