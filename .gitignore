*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.test-deps/
.coverage
.coverage.*
htmlcov/

# Virtual environments and local tooling
.venv/
venv/
env/
.env
.env.*
!.env.example
.idea/
.vscode/
*.code-workspace

