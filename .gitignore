# OpenMedVisionX handles medical images and machine-learning artifacts. These
# rules reduce accidental staging; review new files carefully before committing.

# Python bytecode, test caches, type-checker state, and coverage output
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.tox/
.nox/
.pytype/
.pyre/
.pyright/
.test-deps/
.ipynb_checkpoints/
__pypackages__/
.dmypy.json
dmypy.json
.coverage
.coverage.*
coverage.xml
coverage.json
lcov.info
htmlcov/
test-results/
.benchmarks/

# Local visual-QA captures and partial downloads
/.tmp_*.png
/.tmp_*.jpg
/.tmp_*.jpeg
/.tmp_*.webp
*.download
ground_truth.prefix
observation.prefix

